# Binance API - only needed for live execution; keep blank for dashboard/backtest/paper trading.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_ENABLE_LIVE_TRADING=false

# FRED macro API - optional; yfinance proxies are used if blank.
FRED_API_KEY=

# Alerts - optional. If blank, alerts are logged as dry-run in SQLite compliance_log.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# V5 governance / execution safety
BINANCE_TESTNET=true
REQUIRE_HUMAN_APPROVAL=true
MAX_ORDER_NOTIONAL_PCT_NAV=0.02
MAX_PORTFOLIO_LEVERAGE=1.0
NEWS_API_KEY=
FINNHUB_API_KEY=
